{
  "deniedMcpServers": [
    { "serverName": "Microsoft_Learn" },
    { "serverName": "Microsoft_365" },
    { "serverName": "Google_Drive" }
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "cat \"$CLAUDE_PROJECT_DIR/.claude/hooks/legitimacy-context.json\"",
            "statusMessage": "正当性フレーミングを注入"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git ls-files:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "PowerShell(git status:*)",
      "PowerShell(git diff:*)",
      "PowerShell(git log:*)",
      "PowerShell(& $py tools\\nrs_query.py:*)",
      "PowerShell(& $py tools\\disasm.py:*)",
      "PowerShell(& $py tools\\pe_analyze.py:*)",
      "PowerShell(& $py tools\\nrs_strings.py:*)",
      "PowerShell(& $py tools\\session_summary.py:*)",
      "PowerShell(& $py tools\\read_log.py:*)",
      "PowerShell(& $py tools\\log_analyzer.py:*)",
      "PowerShell(& $py tools\\list_modules.py:*)"
    ]
  }
}
